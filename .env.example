# ============================================================
# Environment Variables Template
# Copy this file to .env and fill in your actual API keys.
# NEVER commit .env to version control.
# ============================================================

# --- Groq ---
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- OpenAI ---
OPENAI_API_KEY=sk-your_openai_api_key_here

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# --- Experiment / scoring (optional) ---
# BENCHMARK_SMOKE=1
# SCORING_RUN_ID=abc12345   # only merge JSONL rows from this run into scored_results.csv
# LEAK_JUDGE=1              # semantic leak check for regex score 3 (needs API key)
# LEAK_JUDGE_MODEL=openai/gpt-4o-mini
